sparql.semscape.org {

    root * /var/www/koetai
    file_server
    
    handle_path /api/* {
        reverse_proxy 127.0.0.1:3000
    }

    # Retired: /endpoint1 -> :7019. Olympics: QLever's demo dataset, off-mission here and down since April.

    # Migrated into the platform as a named graph; the standalone
    # QLever instance on :7026 is gone. 308 keeps method and body so
    # POSTing SPARQL clients follow through.
    handle_path /endpoint2* {
        redir * https://koetai.semscape.org/u/0000-0001-9773-4008/ordo-orphanet/sparql?{query} 308
    }

    # Migrated into the platform as a named graph; the standalone
    # QLever instance on :7027 is gone. 308 keeps method and body so
    # POSTing SPARQL clients follow through.
    handle_path /endpoint3* {
        redir * https://koetai.semscape.org/u/0000-0003-2328-5208/ahri/sparql?{query} 308
    }

    # Retired: /endpoint-fdp -> :7029. The FAIR Data Point is now generated by the platform at koetai.semscape.org/fdp.

    # Retired: /endpoint-wikipathways -> :7028. WikiPathways: the data download had silently failed, so this only ever
    # served 173 triples of VoID metadata. Use the upstream endpoint instead.


    # The FAIR Data Point moved into the platform, which generates it from
    # the datasets themselves. These identifiers were published but never
    # resolved (there was no /fdp/* route), so this is the first time they
    # dereference. 301: the move is permanent.
    redir /fdp/repository https://koetai.semscape.org/fdp 301
    redir /fdp/dataset-ordo https://koetai.semscape.org/fdp/dataset/0000-0001-9773-4008/ordo-orphanet 301
    redir /fdp/dataset-ahri https://koetai.semscape.org/fdp/dataset/0000-0003-2328-5208/ahri 301
    redir /fdp/dist-ordo-sparql https://koetai.semscape.org/fdp/distribution/0000-0001-9773-4008/ordo-orphanet/sparql 301
    redir /fdp/dist-ahri-sparql https://koetai.semscape.org/fdp/distribution/0000-0003-2328-5208/ahri/sparql 301

    handle_path /admin-api/* {
        request_body {
            max_size 500MB
        }
        basic_auth {
            koetai {env.ADMIN_PASSWORD_HASH}
        }
        reverse_proxy 127.0.0.1:3001
    }

    @admin path /admin.html
    basic_auth @admin {
        koetai {env.ADMIN_PASSWORD_HASH}
    }
}

# Koetai Platform (FAIR SPARQL SaaS)
koetai.semscape.org {
    # Large uploads keep their /u/ prefix intact
    handle /u/* {
        request_body {
            max_size 500MB
        }
        reverse_proxy 127.0.0.1:3002
    }

    # Everything else — full path passed through
    handle {
        reverse_proxy 127.0.0.1:3002
    }
}
