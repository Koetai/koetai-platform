# ── Mode ─────────────────────────────────────────────────────────────────────
# community : the hosted public site — ORCID sign-in, registration invite-gated.
#             Requires SECRET_KEY and the ORCID_* settings below.
# internal  : a group hosts it for its members — ORCID sign-in, registration
#             gated by the allowlist below (no per-person invites). Also needs
#             SECRET_KEY and the ORCID_* settings.
# local     : a single-user install on your own machine — no accounts, no ORCID.
#             Everything in the ORCID block below can stay blank.
KOETAI_MODE=community

# Local mode only: the single user the install acts as. The owner slot is
# ORCID-shaped so URLs, graph URIs and FDP metadata look the same either way.
# LOCAL_ORCID=local
# LOCAL_USER_NAME=Local User

# Internal mode only: who may sign up. A first-time ORCID may register if it is
# in INTERNAL_ALLOWED_ORCIDS, or its public ORCID email is under a domain in
# INTERNAL_ALLOWED_DOMAINS (best-effort: only works if the user made an email
# public on ORCID). INTERNAL_ADMIN_ORCIDS are always allowed AND get admin —
# put your own ORCID here to bootstrap a fresh instance. All comma-separated.
# INTERNAL_ADMIN_ORCIDS=0000-0000-0000-0000
# INTERNAL_ALLOWED_ORCIDS=0000-0001-1111-1111,0000-0002-2222-2222
# INTERNAL_ALLOWED_DOMAINS=your-institute.org

SECRET_KEY=change-me-to-a-random-string

# ── ORCID OAuth ──────────────────────────────────────────────────────────────
# Community and internal modes (register at https://orcid.org/developer-tools).
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=your-client-secret
ORCID_REDIRECT_URI=https://koetai.semscape.org/auth/callback

# ── Triplestore backends ─────────────────────────────────────────────────────
# A dataset's `platform` field picks one of these. Configure only the stores you
# actually run; the rest simply report as unavailable.
#
# Supported: qlever, fuseki, virtuoso, oxigraph, blazegraph, rdf4j
QLEVER_PLATFORM_URL=http://localhost:7030
FUSEKI_BASE_URL=http://localhost:3030
FUSEKI_DATASET=koetai
# Only needed if your Fuseki is secured (the docker image is; a bare
# fuseki-server usually is not). Blank = no auth.
# FUSEKI_USER=admin
# FUSEKI_PASSWORD=
# FUSEKI_ADMIN_PASSWORD sets the password inside the bundled container.
# FUSEKI_ADMIN_PASSWORD=change-me
# VIRTUOSO_URL=http://localhost:8890
# VIRTUOSO_USER=dba
# VIRTUOSO_PASSWORD=
# OXIGRAPH_URL=http://localhost:7878
# BLAZEGRAPH_URL=http://localhost:9999/bigdata
# RDF4J_URL=http://localhost:8080/rdf4j-server
# RDF4J_REPO=koetai

# Comunica — a federation engine, not a store. A dataset with platform='comunica'
# holds no uploaded data; it federates queries over a list of external sources
# (its `sources` column). Install with `npm install -g @comunica/query-sparql@^3`
# (pin 3.x — 5.x bundles an undici that breaks on Node 20). Point at the binary:
# COMUNICA_BIN=comunica-sparql
# COMUNICA_TIMEOUT=120

# ── Paths ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=/home/debian/koetai-platform/uploads
DEPLOY_DIR=/home/debian/qlever-sparql-deployment
RUDOF_BIN=/usr/bin/rudof
# Interpreter for the shape-inference / OWL-reasoning subprocesses. Defaults to
# the one running the app, which is almost always right — shexer, owlrl and
# lightrdf are in requirements.txt. Set it only to use a different environment.
# SHEXER_VENV=
# Defaults to ./db/koetai.db — override for a container or a read-only checkout.
# KOETAI_DB_PATH=/data/koetai.db

# ── Base URL ─────────────────────────────────────────────────────────────────
# Local installs typically want http://localhost:3002
BASE_URL=https://koetai.semscape.org

# ── GitHub (for sparql-examples fork sync) ───────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=Koetai
SPARQL_EXAMPLES_REPO=sparql-examples
