# ── Mode ─────────────────────────────────────────────────────────────────────
# community : the hosted multi-tenant site — ORCID sign-in, invitation-gated.
#             Requires SECRET_KEY and the ORCID_* settings below.
# local     : a single-user install on your own machine — no accounts, no ORCID.
#             Everything in the ORCID block below can stay blank.
KOETAI_MODE=community

# Local mode only: the single user the install acts as. The owner slot is
# ORCID-shaped so URLs, graph URIs and FDP metadata look the same either way.
# LOCAL_ORCID=local
# LOCAL_USER_NAME=Local User

SECRET_KEY=change-me-to-a-random-string

# ── ORCID OAuth ──────────────────────────────────────────────────────────────
# Community mode only (register at https://orcid.org/developer-tools).
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=your-client-secret
ORCID_REDIRECT_URI=https://koetai.semscape.org/auth/callback

# ── Triplestore backends ─────────────────────────────────────────────────────
# A dataset's `platform` field picks one of these. Configure only the stores you
# actually run; the rest simply report as unavailable.
#
# Supported: qlever, fuseki, virtuoso, oxigraph, blazegraph, rdf4j
QLEVER_PLATFORM_URL=http://localhost:7030
FUSEKI_BASE_URL=http://localhost:3030
FUSEKI_DATASET=koetai
# VIRTUOSO_URL=http://localhost:8890
# VIRTUOSO_USER=dba
# VIRTUOSO_PASSWORD=
# OXIGRAPH_URL=http://localhost:7878
# BLAZEGRAPH_URL=http://localhost:9999/bigdata
# RDF4J_URL=http://localhost:8080/rdf4j-server
# RDF4J_REPO=koetai

# ── Paths ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=/home/debian/koetai-platform/uploads
DEPLOY_DIR=/home/debian/qlever-sparql-deployment
RUDOF_BIN=/usr/bin/rudof
SHEXER_VENV=/home/debian/koetai-admin/venv/bin/python3
# Defaults to ./db/koetai.db — override for a container or a read-only checkout.
# KOETAI_DB_PATH=/data/koetai.db

# ── Base URL ─────────────────────────────────────────────────────────────────
# Local installs typically want http://localhost:3002
BASE_URL=https://koetai.semscape.org

# ── GitHub (for sparql-examples fork sync) ───────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=Koetai
SPARQL_EXAMPLES_REPO=sparql-examples
